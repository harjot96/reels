# App
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=file:./dev.db

# Claude AI (Script Generation)
ANTHROPIC_API_KEY=sk-ant-...

# ── Text-to-Speech (TTS) ─────────────────────────────────────────────────────
# Edge TTS is ALWAYS available — completely free, no API key, Microsoft neural
# voices, supports Hindi. It is the automatic fallback if no paid key is set.

# Force a specific provider: edge | huggingface | elevenlabs | openai
# Leave blank for auto-cascade: ElevenLabs → Edge TTS → HuggingFace → OpenAI
# TTS_PROVIDER=edge

# ElevenLabs — best quality, Hindi multilingual. From $5/mo: elevenlabs.io
ELEVENLABS_API_KEY=replace-me
ELEVENLABS_DEFAULT_VOICE_ID=EXAVITQu4vr4xnSDxMaL

# OpenAI TTS — great quality, $0.015/1K chars: platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Replicate (AI Video Generation — highest quality, consistent character across clips)
# Get API key at: replicate.com — uses minimax/video-01 model (~$0.01/clip)
# If set, AI video clips are used instead of Pexels or images
REPLICATE_API_KEY=replace-me

# Pexels (Real stock video clips — completely free, used if REPLICATE_API_KEY not set)
# Get your free API key at: pexels.com/api
PEXELS_API_KEY=replace-me

# Hugging Face (AI Image fallback — only used if neither Replicate nor Pexels is set)
# Get token at: huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=hf_...

# Pixabay (Background music for videos — optional, boosts production quality)
# Free API key at: pixabay.com/api/docs/
PIXABAY_API_KEY=replace-me

# YouTube OAuth 2.0 (Google Cloud Console)
YOUTUBE_CLIENT_ID=....apps.googleusercontent.com
YOUTUBE_CLIENT_SECRET=GOCSPX-...
YOUTUBE_REDIRECT_URI=http://localhost:3000/api/auth/youtube/callback

# Instagram Graph API (Meta for Developers)
INSTAGRAM_APP_ID=123456789012345
INSTAGRAM_APP_SECRET=replace-me
INSTAGRAM_REDIRECT_URI=http://localhost:3000/api/auth/instagram/callback
# Graph API version used by Instagram calls
INSTAGRAM_GRAPH_VERSION=v22.0

# Facebook Page Publishing (Meta for Developers)
# Can be the same Meta app as Instagram integration.
FACEBOOK_APP_ID=123456789012345
FACEBOOK_APP_SECRET=replace-me
FACEBOOK_REDIRECT_URI=http://localhost:3000/api/auth/facebook/callback
# Optional (falls back to INSTAGRAM_GRAPH_VERSION if not set)
FACEBOOK_GRAPH_VERSION=v22.0

# Snapchat (Snap Kit — developers.snapchat.com)
# 1. Create a new app at https://kit.snapchat.com/manage
# 2. Enable "Login with Snapchat" and "Snap Audience Network" capabilities
# 3. Add redirect URI: https://yourdomain.com/api/auth/snapchat/callback
# 4. Copy Client ID and Client Secret from the app dashboard
# Note: Video publishing requires a Snapchat Business account with an Ad Account.
SNAPCHAT_CLIENT_ID=replace-me
SNAPCHAT_CLIENT_SECRET=replace-me
SNAPCHAT_REDIRECT_URI=http://localhost:3000/api/auth/snapchat/callback

# Public base URL used to create signed media URLs for Instagram ingestion.
# Must be a public HTTPS URL (localhost will not work for Instagram fetch).
PUBLIC_BASE_URL=https://your-public-domain.com
# Optional separate signing secret (falls back to ENCRYPTION_KEY if omitted)
PUBLIC_FILE_URL_SECRET=replace-me

# Encryption key for YouTube OAuth tokens (exactly 32 chars)
ENCRYPTION_KEY=12345678901234567890123456789012

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage

# Cron job authentication
CRON_SECRET=your_cron_secret_here

# Optional: custom FFmpeg path
# FFMPEG_PATH=/usr/local/bin/ffmpeg
